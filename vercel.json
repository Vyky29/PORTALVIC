{
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "dist/deploy",
  "redirects": [
    {
      "source": "/parents",
      "destination": "/parent",
      "permanent": true
    },
    {
      "source": "/parents/:path*",
      "destination": "/parent/:path*",
      "permanent": true
    },
    {
      "source": "/parents",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent",
      "permanent": false
    },
    {
      "source": "/parents/:path*",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent/:path*",
      "permanent": false
    },
    {
      "source": "/parent",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent",
      "permanent": false
    },
    {
      "source": "/parent/:path*",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent/:path*",
      "permanent": false
    },
    {
      "source": "/re-enrolment",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent/re-enrolment",
      "permanent": false
    },
    {
      "source": "/registration-form",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent/registration",
      "permanent": false
    },
    {
      "source": "/climbing-registration",
      "has": [{ "type": "host", "value": "clubsensational-staff.vercel.app" }],
      "destination": "https://www.clubsensational.org/parent/climbing-registration",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/portal/app-icon/icon-192.png" },
    { "source": "/lead_dashboard.html", "destination": "/staff_dashboard.html" },
    { "source": "/lead-dashboard.webmanifest", "destination": "/staff-dashboard.webmanifest" },
    { "source": "/", "destination": "/login.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/portal-choose", "destination": "/portal_choose.html" },
    { "source": "/session_feedback.html", "destination": "/portal-session-feedback.html" },
    { "source": "/incident_report.html", "destination": "/portal-incident.html" },
    { "source": "/cancellation_report.html", "destination": "/cancellation.html" },
    { "source": "/session_disruption.html", "destination": "/session_disruption_report.html" },
    { "source": "/expenses.html", "destination": "/portal-expenses.html" },
    { "source": "/pickup.html", "destination": "/portal-pickup.html" },
    { "source": "/venue_review.html", "destination": "/portal-venue-review.html" },
    { "source": "/lead_feedback_report.html", "destination": "/portal-lead-feedback.html" },
    { "source": "/contract-sign", "destination": "/contract_sign.html" },
    { "source": "/contract-sign/:id", "destination": "/contract_sign.html?contract_id=:id" },
    { "source": "/hr-contract", "destination": "/hr_contract.html" },
    { "source": "/hr_contract", "destination": "/hr_contract.html" },
    { "source": "/hr_contract/", "destination": "/hr_contract.html" },
    { "source": "/portal-guide", "destination": "/portal_guide.html" },
    { "source": "/guide", "destination": "/portal_guide.html" },
    { "source": "/policies", "destination": "/policies_portal.html" },
    { "source": "/policies_portal", "destination": "/policies_portal.html" },
    { "source": "/risk-assessment", "destination": "/risk_assessment.html" },
    { "source": "/risk_assessment", "destination": "/risk_assessment.html" },
    { "source": "/ra_portal", "destination": "/risk_assessment.html" },
    { "source": "/ra_portal.html", "destination": "/risk_assessment.html" },
    { "source": "/staff-wellbeing-review", "destination": "/staff_wellbeing_review.html" },
    { "source": "/wellbeing-review", "destination": "/staff_wellbeing_review.html" },
    { "source": "/ld-funding", "destination": "/staff_ld_funding_apply.html" },
    { "source": "/ld-funding-apply", "destination": "/staff_ld_funding_apply.html" },
    { "source": "/timesheet", "destination": "/timesheet.html" },
    { "source": "/general-induction", "destination": "/general-induction/index.html" },
    { "source": "/induction", "destination": "/general-induction/index.html" },
    { "source": "/sw-term-review", "destination": "/swtermreview.html" },
    { "source": "/sw-term-review/", "destination": "/swtermreview.html" },
    { "source": "/parent/climbing-registration", "destination": "/climbing_registration.html" },
    { "source": "/parent/re-enrolment", "destination": "/parent_reenrolment.html" },
    { "source": "/parent/re-enrolment-form", "destination": "/parent_reenrolment.html" },
    { "source": "/parent/re-enrol", "destination": "/parent_reenrolment.html" },
    { "source": "/re-enrolment", "destination": "/parent_reenrolment.html" },
    { "source": "/re-enrolment-form", "destination": "/parent_reenrolment.html" },
    { "source": "/parent/crash-summer", "destination": "/parent_crash_summer_2026.html" },
    { "source": "/parent/crash-courses", "destination": "/parent_crash_summer_2026.html" },
    { "source": "/parent/registration", "destination": "/parent_registration.html" },
    { "source": "/bookingservice", "destination": "/bookingservice.html" },
    { "source": "/bookingservice/", "destination": "/bookingservice.html" },
    { "source": "/booking-service", "destination": "/bookingservice.html" },
    { "source": "/parent/app", "destination": "/parent_portal.html" },
    { "source": "/parent/login", "destination": "/parent_portal.html" },
    { "source": "/parent/portal", "destination": "/parent_portal.html" },
    { "source": "/parent", "destination": "/parent_portal.html" },
    { "source": "/climbing-registration", "destination": "/climbing_registration.html" },
    { "source": "/climbing_registration", "destination": "/climbing_registration.html" },
    { "source": "/parent_climbing_registration.html", "destination": "/climbing_registration.html" },
    { "source": "/registration-form", "destination": "/parent_registration.html" }
  ],
  "headers": [
    {
      "source": "/portal/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/portal/(.*\\.css)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/portal-shared-js/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/portal-static-bootstrap.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/login.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/admin_dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/staff_dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/lead_dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/portal-session-feedback.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/portal_help_guide.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/session_feedback.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/cs_cliq.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}

{
  "outputDirectory": "working_ui",
  "rewrites": [
    { "source": "/", "destination": "/login.html" },
    { "source": "/adminportal", "destination": "/admin_dashboard.html" },
    { "source": "/adminportal/", "destination": "/admin_dashboard.html" },
    { "source": "/operations-admin", "destination": "/admin_dashboard.html" },
    { "source": "/operations-admin/", "destination": "/admin_dashboard.html" },
    { "source": "/l0", "destination": "/login.html" },
    { "source": "/l0/", "destination": "/login.html" },
    { "source": "/p1", "destination": "/staff_dashboard.html" },
    { "source": "/p1/", "destination": "/staff_dashboard.html" },
    { "source": "/l1", "destination": "/lead_dashboard.html" },
    { "source": "/l1/", "destination": "/lead_dashboard.html" },
    { "source": "/ce", "destination": "/ceo_dashboard.html" },
    { "source": "/ce/", "destination": "/ceo_dashboard.html" },
    { "source": "/portal/admin_embed.html", "destination": "/admin_dashboard.html" },
    { "source": "/contract-sign", "destination": "/contract_sign.html" },
    { "source": "/contract-sign/:id", "destination": "/contract_sign.html?contract_id=:id" },
    { "source": "/hr-contract", "destination": "/hr_contract.html" }
  ]

# Portal local secrets — SOLO en tu máquina (local-secrets/secrets.env)
# No subir a git. Copiado por database/bootstrap-local-vault.ps1

# Supabase Portal (cklpnwhlqsulpmkipmqb)
SUPABASE_URL=https://cklpnwhlqsulpmkipmqb.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push — Edge Function secrets
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@clubsensational.org
# Parent notify email — Google Workspace SMTP (portal-parent-notify-send)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@clubsensational.org
SMTP_PASS=
SMTP_FROM=clubSENsational <info@clubsensational.org>
PORTAL_MAIL_FROM=admin@clubsensational.org
PORTAL_MAIL_REPLY_TO=info@clubsensational.org
PORTAL_MAIL_SAFEGUARDING=management@clubsensational.org
# OpenAI — portal-openai-assist + portal-feedback-voice-transcribe (Whisper)
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini)
PORTAL_OPENAI_MODEL=gpt-4o-mini

# ElevenLabs — portal-help-voice-speak + generate-help-guide-audio.mjs
# Same names in Supabase Dashboard → Edge Functions → Secrets (Portal cklpnwhlqsulpmkipmqb).
# Redeploy portal-help-voice-speak after changing Supabase secrets.
ELEVENLABS_API_KEY=
# Voice ID from ElevenLabs → Voices. Default if empty: club voice (3WqHLnw80rOZqJzW9YRB)
ELEVENLABS_VOICE_ID=3WqHLnw80rOZqJzW9YRB
# Optional model (Edge default: eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# WhatsApp — two numbers (recommended):
#   • API number (NEW) — portal outbound only (OTP, parent notify). Values below = this number.
#   • Company number — WhatsApp Business app on staff phone (manual chats). NOT in these secrets.
# After buying the API SIM: Meta Business Suite → add number → copy Phone number ID here.
# Run: npm run apply:whatsapp — then Admin → Settings → Send test WhatsApp.
# Replies to API sends: Meta Business Suite inbox (link in Admin → Settings).
# Parent notify WhatsApp (optional template for cold outbound — Meta approved name)
# Parent notify WhatsApp — Meta approved template(s). See database/META-WHATSAPP-PARENT-NOTIFY-TEMPLATES.md
# One generic template ({{1}} = message body) is enough for all kinds:
PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE=portal_parent_update
# Meta webhook (V3 — inbound replies in Family messages). Generate a random verify token:
# META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-long-random-string
# App secret from Meta app dashboard → Settings → Basic (for X-Hub-Signature-256):
# META_WHATSAPP_APP_SECRET=
# Optional per-kind overrides (same {{1}} pattern):
# PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE_PAYMENT=portal_parent_payment
# PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE_INSTRUCTOR=portal_parent_instructor
# PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE_ABSENCE=portal_parent_absence
# PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE_MAKEUP=portal_parent_makeup
# PORTAL_PARENT_NOTIFY_WHATSAPP_TEMPLATE_BOOKING=portal_parent_booking
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_TEMPLATE_LANG=en_US
PORTAL_PUSH_OPEN_URL=https://portalvic.vercel.app/staff_dashboard.html
# Admin/CEO bell (late submissions, chat, incidents, cancellations). Optional if staff URL ends with staff_dashboard.html (auto-derived).
PORTAL_PUSH_ADMIN_OPEN_URL=https://portalvic.vercel.app/admin_dashboard.html
PORTAL_PUSH_WEBHOOK_SECRET=

# Payroll monthly report — pg_cron header x-payroll-cron-secret (Edge Function PAYROLL_CRON_SECRET)
PAYROLL_CRON_SECRET=
# Resend — payroll-monthly-report send mode (cron + payroll-report.html)
RESEND_API_KEY=
PAYROLL_REPORT_FROM=clubSENsational Payroll <admin@clubsensational.org>
PAYROLL_REPORT_TO=sevitha@clubsensational.org,victor@clubsensational.org

# Webhook header (mismo valor que PORTAL_PUSH_WEBHOOK_SECRET)
# Nombre: x-portal-webhook-secret

# Otros
STAFF_PROFILE_PORTAL_BRIDGE_SECRET=

# Onboarding forms — Make.com custom webhook URLs (submit only)
ONBOARDING_JOB_APPLICATION_MAKE_WEBHOOK_URL=
ONBOARDING_HEALTH_QUESTIONNAIRE_MAKE_WEBHOOK_URL=

# GoCardless — Direct Payment (Edge Function secrets; sandbox first)
# Sandbox dashboard: https://manage-sandbox.gocardless.com → Developers → Access token (Read-Write)
# Live later: https://manage.gocardless.com (separate token + webhook)
# Also set in Supabase → Edge Functions → Secrets (Portal cklpnwhlqsulpmkipmqb)
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_WEBHOOK_SECRET=
